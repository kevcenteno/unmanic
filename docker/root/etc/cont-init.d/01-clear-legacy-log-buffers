#!/usr/bin/env bash

log_cleanup() {
    echo "**** (legacy-log-cleanup) $*"
}

buffer_dir="/config/.unmanic/logs/buffer"
state_file="buffer_state.json"

if [[ ! -d "${buffer_dir}" ]]; then
    log_cleanup "No log buffer directory at ${buffer_dir}; skipping legacy cleanup"
    return 0
fi

shopt -s nullglob
removed=0
for legacy_path in "${buffer_dir}"/*.json; do
    if [[ "$(basename "${legacy_path}")" == "${state_file}" ]]; then
        continue
    fi
    if rm -f -- "${legacy_path}"; then
        removed=$((removed + 1))
    else
        log_cleanup "Failed to remove legacy buffer file ${legacy_path}"
    fi
done
shopt -u nullglob

if [[ "${removed}" -gt 0 ]]; then
    log_cleanup "Removed ${removed} legacy log buffer file(s)"
else
    log_cleanup "No legacy log buffer files found"
fi
